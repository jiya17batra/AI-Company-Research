# --- Required ---

# Get a key at https://serper.dev (free tier available)
SERPER_API_KEY=your_serper_api_key_here

# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# --- Optional ---

# Used in the OpenRouter request headers (HTTP-Referer). Set this to your
# deployed URL once live (e.g. https://your-app.vercel.app).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Discord bonus feature ---
# These are NOT set as environment variables — they are entered by the user
# at runtime via the "Discord Settings" panel in the UI (bot token + channel
# ID are provided by the evaluator per the assignment, not hardcoded).
